# Mission Control — Environment Variables

# Convex deployment URL (required)
# Get this from: https://dashboard.convex.dev/ → your project → Settings → Deployment URL
NUXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# App settings
NUXT_PUBLIC_APP_NAME=Agents Mission Control

# Session secret for auth (auto-generated if not set)
SESSION_SECRET=change-me-to-a-random-string-in-production
